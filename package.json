{
  "name": "zoho-web-pages-workflow",
  "private": true,
  "description": "Maintenance scripts for the Zoho Web Page Builder workflow",
  "scripts": {
    "commands": "node z_workflow/scripts/list-commands.mjs",
    "audit": "node z_workflow/scripts/site-audit.mjs",
    "audit:webtemplate": "node z_workflow/scripts/audit-webtemplate-sitemap.mjs --resume --concurrency 8",
    "find:webtemplate": "node z_workflow/scripts/find-webtemplate-section.mjs",
    "select:end-banner": "node z_workflow/scripts/select-end-banner.mjs",
    "match": "node z_workflow/scripts/match-sites.mjs",
    "match:validate": "node z_workflow/scripts/match-sites.mjs --validate",
    "extract:writer": "node z_workflow/scripts/extract-writer.mjs",
    "validate:brief": "node z_workflow/scripts/validate-brief.mjs",
    "validate:output": "node z_workflow/scripts/validate-output.mjs",
    "fix:output": "node z_workflow/scripts/fix-output-archetype.mjs",
    "promote": "node z_workflow/scripts/promote-output.mjs",
    "organize": "node z_workflow/scripts/organize-reference-sites.mjs"
  },
  "devDependencies": {
    "puppeteer": "^24.0.0"
  }
}
