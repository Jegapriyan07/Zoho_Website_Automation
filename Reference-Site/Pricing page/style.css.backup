}

.pricing-tab {
    display: flex;
    border-radius: 24px;
    border: 1px solid #FFF;
    background: rgba(255, 255, 255, 0.40);
    padding: 4px;
    box-sizing: border-box;
    align-items: center
}

.pricing-wrap .pricing-tab>span.monthly,
.pricing-wrap .pricing-tab>span.yearly {
    border: 0 !important;
    color: #767676 !important;
    position: relative;
    border-radius: 24px !important;
    background: transparent !important;
    font-family: var(--zf-primary-semibold);
    transition: all 0.3s ease-in-out;
}

.pricing-tab>span.yearly.active,
.pricing-tab>span.monthly.active {
    border-radius: 24px !important;
    border: none !important;
    background: linear-gradient(0, rgba(0, 0, 0, 0.20) 0, rgba(0, 0, 0, 0.20) 100%), linear-gradient(90deg, #008ef5 0, #9914ff 100%) !important;
    color: #fff !important;
    transition: all 0.3s ease-in-out;
}

.pricing-tab>span {
    padding: 8px 12px;
    display: inline-flex;
    border: unset !important;
    font-family: var(--zf-primary-semibold);
    color: #666 !important;
