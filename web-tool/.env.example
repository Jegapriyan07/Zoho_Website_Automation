# ─────────────────────────────────────────────────────────────
# Zoho Web Page Builder Tool — environment config
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# App
PORT=4310
# Origin the app is served from (used to build the OAuth redirect URI)
APP_BASE_URL=http://localhost:4310

# Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# 64 hex chars (32 bytes) — encrypts Zoho tokens at rest (AES-256-GCM)
TOKEN_ENC_KEY=change-me-64-hex-chars
# Signs the session cookie (any long random string)
SESSION_SECRET=change-me-long-random-string

# ─── Zoho OAuth2 (Zoho Accounts) ───────────────────────────────
# Create a "Server-based Application" at https://api-console.zoho.com
# Redirect URI must be:  ${APP_BASE_URL}/auth/zoho/callback
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Accounts base for your DC: .com | .in | .eu | .com.au | .jp
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
# Scopes the Writer extraction needs
ZOHO_SCOPE=ZohoWriter.documents.READ,AaaServer.profile.READ

# ─── Pipeline (existing repo) ──────────────────────────────────
# Absolute path to the Web-pages repo root (the parent of this web-tool folder).
# Leave blank to auto-detect (../ from this folder).
PIPELINE_ROOT=

# ─── Phase 1/2/6 composer ──────────────────────────────────────
# Page composition is AGENT (LLM) work — there is no deterministic script for it.
# The orchestrator invokes this command to compose index.html/style.css/script.js.
# It receives the build context on stdin (JSON) and must write the 3 files into
# output/<slug>/ then exit 0. Leave blank to run in MANUAL mode (the run pauses at
# a hard stop asking a human/agent to compose, instead of emitting garbage).
#
# Example (Cursor CLI headless — auto-wrapped with connection-loss retries):
# COMPOSER_CMD=cursor-agent -p --force --output-format text
# Composition model. Default is composer-2.5 for lower token cost. Options:
#   composer-2.5                    (default — fastest, lowest cost)
#   claude-sonnet-5-thinking-high   (stronger quality, higher cost)
#   claude-opus-4-8-thinking-high   (max quality, slowest/costliest)
# COMPOSER_MODEL=composer-2.5
COMPOSER_CMD=
